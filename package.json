{
  "name": "daycard-image",
  "version": "1.4.1",
  "description": "拾光匣 - 日更壁纸 · 拾光成匣",
  "main": "dist-electron/main.js",
  "author": "DayCard-Image Team",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "dev:electron": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "vite build && tsc -p tsconfig.electron.json",
    "build:electron": "npm run build && electron-builder",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ electron/ --ext .ts,.tsx",
    "lint:fix": "eslint src/ electron/ --ext .ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx}\" \"electron/**/*.ts\"",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "auto-launch": "^5.0.6",
    "electron-updater": "^6.8.3",
    "lucide-react": "^1.16.0",
    "node-cron": "^4.2.1",
    "openai": "^4.47.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "sharp": "^0.34.5",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@types/node-cron": "^3.0.11",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/sharp": "^0.31.1",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.0",
    "concurrently": "^8.2.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0",
    "eslint": "^8.57.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-import-resolver-typescript": "^3.6.0",
    "eslint-plugin-import": "^2.29.0",
    "eslint-plugin-react": "^7.33.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "postcss": "^8.4.0",
    "prettier": "^3.2.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.3.0",
    "vite": "^5.1.0",
    "vitest": "^1.3.0",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.daycard-image.app",
    "productName": "拾光匣",
    "publish": {
      "provider": "github",
      "owner": "skyblueeedemo",
      "repo": "DayCard-Image"
    },
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "!config/**/*",
      "!**/*.map",
      "!**/node_modules/.cache/**"
    ],
    "mac": {
      "target": "dmg"
    },
    "win": {
      "target": "nsis",
      "signAndEditExecutable": false,
      "signDlls": false
    },
    "nsis": {
      "include": "build/installer.nsh",
      "deleteAppDataOnUninstall": true
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
